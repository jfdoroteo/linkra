require_once $_SERVER['DOCUMENT_ROOT'].'/linkra/partials/video-embed.php';
$q        = clean($conn, $_GET['q']        ?? '');
$platform = clean($conn, $_GET['platform'] ?? '');
$category = clean($conn, $_GET['category'] ?? '');

$where = "p.status='open'";
if ($q)        $where .= " AND p.title LIKE '%$q%'";
if ($platform) $where .= " AND p.platform='$platform'";
if ($category) $where .= " AND p.category='$category'";

$camps = $conn->query("SELECT p.*,b.company_name,b.industry,
    (SELECT COUNT(*) FROM submissions WHERE project_id=p.id) subs,
    (SELECT COUNT(*) FROM submissions WHERE project_id=p.id AND creator_id={$user['id']}) mine
    FROM projects p JOIN businesses b ON b.user_id=p.business_id
    WHERE $where ORDER BY p.created_at DESC");
