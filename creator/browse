  </div>
  <div class="campaign-card-body">
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px">
      <span class="badge badge-<?=$p['platform']?>"><?=strtoupper($p['platform'])==='ALL'?'All platforms':strtoupper($p['platform'])?></span>
