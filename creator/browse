      <span class="badge badge-<?=$p['content_type']?>"><?=ucwords(str_replace('-',' ',$p['content_type']))?></span>
      <?php if($p['category']): ?><span class="badge badge-<?=strtolower($p['category'])?>"><?=$p['category']?></span><?php endif; ?>
