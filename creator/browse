  <form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;flex:1">
    <input type="text" name="q" class="form-control" placeholder="Search campaigns..." value="<?=htmlspecialchars($q)?>" style="max-width:240px">
    <select name="platform" class="form-control" style="max-width:180px" onchange="this.form.submit()">
      <option value="">All platforms</option>
