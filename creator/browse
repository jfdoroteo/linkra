    <div class="campaign-meta mb-12">
      <?php if($p['payout_per_1k']>0): ?><span class="meta-item" style="color:var(--purple);font-weight:600"><i class="ti ti-coin"></i><?=peso($p['payout_per_1k'])?>/1K views</span><?php endif; ?>
      <?php if($p['max_payout_per_creator']>0): ?><span class="meta-item"><i class="ti ti-user-dollar"></i>Max <?=peso($p['max_payout_per_creator'])?></span><?php endif; ?>
      <?php if($p['deadline']): ?><span class="meta-item"><i class="ti ti-calendar"></i>Due <?=date('M j',strtotime($p['deadline']))?></span><?php endif; ?>
      <span class="meta-item"><i class="ti ti-send"></i><?=$p['subs']?> submitted</span>
    </div>
    <div class="campaign-actions">
      <a href="/linkra/creator/campaign.php?id=<?=$p['id']?>" class="btn btn-secondary btn-sm"><i class="ti ti-eye"></i>View brief</a>
      <?php if($has_submitted): ?>
      <span class="badge badge-approved" style="padding:6px 12px"><i class="ti ti-check"></i>Submitted</span>
