$q        = clean($conn,$_GET['q']??'');
$platform = clean($conn,$_GET['platform']??'all');
$ctype    = clean($conn,$_GET['type']??'all');
$cat      = clean($conn,$_GET['cat']??'');
$where    = "p.status='open'";
if ($q)              $where .= " AND (p.title LIKE '%$q%' OR p.description LIKE '%$q%')";
if ($platform!=='all') $where .= " AND (p.platform='$platform' OR p.platform='all')";
if ($ctype!=='all')  $where .= " AND (p.content_type='$ctype' OR p.content_type='both')";
if ($cat)            $where .= " AND p.category='$cat'";
$camps = $conn->query("SELECT p.*,b.company_name,u.name bname,u.avatar bavatar,(SELECT COUNT(*) FROM submissions WHERE project_id=p.id) subs FROM projects p JOIN users u ON u.id=p.business_id LEFT JOIN businesses b ON b.user_id=p.business_id WHERE $where ORDER BY p.created_at DESC");
$already = [];
$my_subs = $conn->query("SELECT project_id FROM submissions WHERE creator_id={$user['id']}");
if ($my_subs) while($r=$my_subs->fetch_assoc()) $already[]=$r['project_id'];
?>
